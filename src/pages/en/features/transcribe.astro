---
import Layout from '../../../layouts/Layout.astro';
import MobileTease from '../../../components/MobileTease.astro';
const APP_URL = 'https://dev-app.audioask.ai';
---

<Layout
  title="Transcribe any podcast to text — Audioask"
  description="Transcribe any podcast episode in minutes. Accurate, timestamped and searchable text. Speaker identification, full-text search, community network effect."
  activePage="features"
  lang="en"
  alternatePath="/fonctionnalites/transcrire"
>

  <!-- HERO -->
  <section class="hero dotbg">
    <div class="container">
      <div class="hero-copy" style="text-align: left; max-width: 1280px;">
        <div class="page-intro">Feature 01 · Transcribe</div>
        <div class="transcrire-hero-grid" style="display: grid; grid-template-columns: 1.1fr 1fr; gap: 80px; align-items: center;">
          <div>
            <h1 style="text-align: left;">
              Transcribe any podcast in <span class="em-serif">minutes.</span>
            </h1>
            <p class="lede" style="margin-top: 24px; text-align: left;">
              Stop rewinding. Stop taking notes on the fly. Audioask turns your episodes into accurate, timestamped and searchable text.
            </p>
            <div class="hero-ctas" style="margin-top: 32px;">
              <a class="btn btn-primary lg" href={`${APP_URL}/signup`}>Transcribe my first episode <span class="arrow">→</span></a>
              <a class="btn lg" href="#">See an example</a>
            </div>
            <div class="hero-meta" style="margin-top: 18px;">
              <span class="dotcheck">2 free transcriptions included</span>
              <span class="dotcheck">No card required</span>
            </div>
          </div>

          <!-- Hero visual : transcription in progress -->
          <div class="transcrire-hero-visual" style="position: relative;">
            <div class="app-card" style="max-width: 100%;">
              <div class="app-toolbar">
                <span class="dot"></span><span class="dot"></span><span class="dot"></span>
                <span class="url">audioask.ai · transcription</span>
              </div>
              <div style="padding: 22px 24px; background: var(--cream);">
                <div style="display: flex; align-items: center; gap: 14px;">
                  <div class="ep-cover" style="width: 56px; height: 56px; background: linear-gradient(135deg, #B5915B, #8C6A38); font-size: 11px;">
                    <span class="label" style="font-size: 7px;">TKP</span>
                    <span style="font-family: var(--serif); font-size: 14px; font-style: italic;">218</span>
                  </div>
                  <div style="flex: 1; min-width: 0;">
                    <div style="font-size: 14px; font-weight: 600; letter-spacing: -0.015em;">The Knowledge Project · #218</div>
                    <div style="font-size: 11.5px; color: var(--ink-3); margin-top: 2px;">Shane Parrish · 1h 06min</div>
                  </div>
                  <span class="chip accent-soft"><span style="width: 6px; height: 6px; border-radius: 50%; background: var(--accent); display: inline-block; animation: pulse 1.4s ease-in-out infinite;"></span> In progress</span>
                </div>

                <!-- Progress card -->
                <div style="margin-top: 14px; padding: 14px 16px; background: var(--paper); border: 1px solid var(--accent); border-radius: 12px;">
                  <div style="display: flex; justify-content: space-between; font-family: var(--mono); font-size: 11px; color: var(--accent-ink);">
                    <span>TRANSCRIPTION · 67%</span><span>1m 12s remaining</span>
                  </div>
                  <div style="margin-top: 8px; height: 6px; background: var(--accent-tint); border-radius: 3px;">
                    <div style="height: 100%; width: 67%; background: var(--accent); border-radius: 3px;"></div>
                  </div>
                  <div style="margin-top: 10px; font-size: 12px; color: var(--ink-2); display: flex; flex-direction: column; gap: 4px;">
                    <div style="display: flex; gap: 8px;"><span style="color: var(--accent);">✓</span> Audio analysed · 1h 06min</div>
                    <div style="display: flex; gap: 8px;"><span style="color: var(--accent);">✓</span> Timestamps synchronised</div>
                    <div style="display: flex; gap: 8px;"><span style="color: var(--accent); animation: pulse 1.4s infinite;">●</span> <span>Text transcription in progress…</span></div>
                  </div>
                </div>

                <!-- Transcript preview (live) -->
                <div style="margin-top: 14px;">
                  <div style="font-family: var(--mono); font-size: 10px; color: var(--ink-3); letter-spacing: 0.08em; margin-bottom: 8px;">TRANSCRIPTION · LIVE</div>
                  <div style="display: flex; flex-direction: column; gap: 6px; font-size: 12px; line-height: 1.5;">
                    <div style="display: grid; grid-template-columns: 56px 1fr; gap: 10px;"><span style="font-family: var(--mono); color: var(--ink-3); font-size: 10.5px; padding-top: 1px;">00:00</span><span>Welcome to this episode. Today we're talking about decision-making…</span></div>
                    <div style="display: grid; grid-template-columns: 56px 1fr; gap: 10px;"><span style="font-family: var(--mono); color: var(--ink-3); font-size: 10.5px; padding-top: 1px;">02:14</span><span>Thanks for having me. The first thing I learned is that you need to…</span></div>
                    <div style="display: grid; grid-template-columns: 56px 1fr; gap: 10px;"><span style="font-family: var(--mono); color: var(--ink-3); font-size: 10.5px; padding-top: 1px;">04:18</span><span>Let's go back to your background and your first ventures…</span></div>
                    <div style="display: grid; grid-template-columns: 56px 1fr; gap: 10px; opacity: 0.4;"><span style="font-family: var(--mono); font-size: 10.5px; padding-top: 1px;">…</span><span style="display: inline-flex; align-items: center; gap: 6px;"><span style="width: 5px; height: 14px; background: var(--accent); display: inline-block; animation: pulse 1s infinite;"></span> transcription in progress…</span></div>
                  </div>
                </div>
              </div>
            </div>

            <!-- Floating annotation -->
            <div class="float" style="bottom: -28px; right: -28px; max-width: 200px;">
              <span class="lbl">Average time</span>
              <span class="val" style="font-family: var(--serif); font-size: 26px; line-height: 1; letter-spacing: -0.02em;">~3 min</span>
              <span style="font-size: 11px; color: var(--ink-3);">per 1h of audio</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <style>
    @keyframes pulse { 0%,100% { opacity: 1; } 50% { opacity: 0.3; } }

    @media (max-width: 768px) {
      .transcrire-hero-grid { grid-template-columns: 1fr !important; gap: 40px !important; }
      .transcrire-hero-visual { display: none; }
      .pour-qui-grid { grid-template-columns: 1fr !important; }
    }
    @media (max-width: 480px) {
      .transcrire-hero { padding: 48px 0 40px !important; }
    }
  </style>

  <!-- HOW IT WORKS -->
  <section class="section alt">
    <div class="container">
      <div class="row between" style="align-items: flex-end; flex-wrap: wrap; gap: 32px;">
        <div>
          <div class="eyebrow"><span class="dot">●</span> How it works</div>
          <h2 style="margin-top: 16px;">3 steps.<br><span class="serif-it">No technical skills needed.</span></h2>
        </div>
      </div>

      <div class="steps">
        <div class="step">
          <span class="step-num">STEP 01</span>
          <h4>Add a channel or episode</h4>
          <p style="font-size: 14px; color: var(--ink-2);">Search directly in Audioask among thousands of podcasts, or paste the RSS URL.</p>
          <div class="step-illu" style="padding: 16px 18px;">
            <div style="background: var(--paper); border: 1px solid var(--line); border-radius: 10px; padding: 9px 12px; display: flex; align-items: center; gap: 8px; font-size: 13px;">
              <span style="color: var(--ink-3);">⌕</span>
              <span style="color: var(--ink);">acquired</span>
              <span style="margin-left: auto; width: 5px; height: 16px; background: var(--accent); display: inline-block; animation: pulse 1s infinite;"></span>
            </div>
            <div style="margin-top: 8px; display: flex; flex-direction: column; gap: 5px;">
              <div style="background: var(--paper); border: 1px solid var(--accent); border-radius: 8px; padding: 7px 10px; display: flex; align-items: center; gap: 9px;">
                <span style="width: 28px; height: 28px; border-radius: 6px; background: linear-gradient(135deg, #5B7FD9, #2E4FB5); flex-shrink: 0;"></span>
                <div style="flex: 1; min-width: 0;">
                  <div style="font-size: 12px; font-weight: 600;">Acquired</div>
                  <div style="font-size: 10px; color: var(--ink-3);">Ben Gilbert &amp; David Rosenthal</div>
                </div>
                <span style="font-size: 10px; padding: 3px 8px; background: var(--accent); color: white; border-radius: 6px;">Follow</span>
              </div>
              <div style="background: var(--paper); border: 1px solid var(--line); border-radius: 8px; padding: 7px 10px; display: flex; align-items: center; gap: 9px;">
                <span style="width: 28px; height: 28px; border-radius: 6px; background: linear-gradient(135deg, #C44A5F, #8E2C40); flex-shrink: 0;"></span>
                <div style="flex: 1; min-width: 0;">
                  <div style="font-size: 12px; font-weight: 600;">Acquired LP Show</div>
                  <div style="font-size: 10px; color: var(--ink-3);">Bonus &amp; interviews</div>
                </div>
                <span style="font-size: 10px; padding: 3px 8px; background: var(--cream-2); color: var(--ink-2); border: 1px solid var(--line); border-radius: 6px;">Follow</span>
              </div>
            </div>
          </div>
        </div>
        <div class="step">
          <span class="step-num">STEP 02</span>
          <h4>Launch transcription</h4>
          <p style="font-size: 14px; color: var(--ink-2);">One click. Our engine processes audio in 2 to 5 minutes for a 60-minute episode.</p>
          <div class="step-illu" style="display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 12px;">
            <div style="width: 64px; height: 64px; border-radius: 50%; background: var(--accent); color: white; display: flex; align-items: center; justify-content: center; font-size: 24px;">✦</div>
            <div style="font-family: var(--mono); font-size: 11px; color: var(--accent-ink);">Transcription · 41%</div>
            <div style="width: 60%; height: 4px; background: var(--cream-3); border-radius: 2px;">
              <div style="width: 41%; height: 100%; background: var(--accent); border-radius: 2px;"></div>
            </div>
          </div>
        </div>
        <div class="step">
          <span class="step-num">STEP 03</span>
          <h4>Read, search, share</h4>
          <p style="font-size: 14px; color: var(--ink-2);">Full transcript with speakers and timestamps. Exportable in one click.</p>
          <div class="step-illu" style="padding: 14px;">
            <div style="display: flex; flex-direction: column; gap: 5px; font-size: 11px;">
              <div style="display: grid; grid-template-columns: 42px 1fr; gap: 8px;"><span style="font-family: var(--mono); color: var(--accent); font-size: 9.5px;">00:00</span><span style="color: var(--ink-2); white-space: nowrap; overflow: hidden; text-overflow: ellipsis;">Welcome to this episode where…</span></div>
              <div style="display: grid; grid-template-columns: 42px 1fr; gap: 8px;"><span style="font-family: var(--mono); color: var(--accent); font-size: 9.5px;">04:18</span><span style="color: var(--ink-2); white-space: nowrap; overflow: hidden; text-overflow: ellipsis;">Before Nvidia, the GPU market…</span></div>
              <div style="display: grid; grid-template-columns: 42px 1fr; gap: 8px;"><span style="font-family: var(--mono); color: var(--accent); font-size: 9.5px;">12:42</span><span style="background: var(--accent-soft); color: var(--accent-ink); padding: 1px 4px; border-radius: 3px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis;">« We bet on CUDA when… »</span></div>
              <div style="display: grid; grid-template-columns: 42px 1fr; gap: 8px;"><span style="font-family: var(--mono); color: var(--accent); font-size: 9.5px;">28:05</span><span style="color: var(--ink-2); white-space: nowrap; overflow: hidden; text-overflow: ellipsis;">And that's exactly when…</span></div>
              <div style="display: grid; grid-template-columns: 42px 1fr; gap: 8px;"><span style="font-family: var(--mono); color: var(--accent); font-size: 9.5px;">38:50</span><span style="color: var(--ink-2); white-space: nowrap; overflow: hidden; text-overflow: ellipsis;">The datacenter market…</span></div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- DETAILED FEATURES -->
  <section class="section">
    <div class="container">
      <div style="max-width: 720px;">
        <div class="eyebrow"><span class="dot">●</span> Under the hood</div>
        <h2 style="margin-top: 16px;">What Audioask transcription <span class="serif-it">really does</span> for you.</h2>
      </div>

      <!-- Feature 1 : Speed -->
      <div class="feature-alt" style="margin-top: 48px;">
        <div>
          <div class="eyebrow"><span style="color: var(--accent);">01</span> · Speed</div>
          <h3 style="margin-top: 12px;">From audio to text in minutes.</h3>
          <p>Our engine processes a 60-minute episode in 2 to 5 minutes. The result is structured with identified speakers and clickable timestamps — with zero manual intervention.</p>
          <div style="margin-top: 24px; display: flex; gap: 18px; flex-wrap: wrap;">
            <div>
              <div style="font-family: var(--serif); font-size: 44px; line-height: 1; letter-spacing: -0.03em; color: var(--accent-ink);">~3 min</div>
              <div style="font-size: 12px; color: var(--ink-3); margin-top: 4px; font-family: var(--mono); letter-spacing: 0.05em;">PER 1h OF AUDIO</div>
            </div>
          </div>
        </div>
        <div class="demo" style="background: var(--cream-2); padding: 24px; display: flex; flex-direction: column; gap: 14px;">
          <div style="font-family: var(--mono); font-size: 10px; color: var(--ink-3); letter-spacing: 0.08em;">PROGRESS · EPISODE #218</div>
          <div style="background: var(--paper); border-radius: 10px; padding: 14px 16px; border: 1px solid var(--line);">
            <div style="display: flex; justify-content: space-between; font-size: 11px; color: var(--ink-2); margin-bottom: 8px;"><span>Audio analysis</span><span style="font-family: var(--mono); color: var(--accent);">✓ 0:14s</span></div>
            <div style="height: 4px; background: var(--cream-3); border-radius: 2px; overflow: hidden;"><div style="width: 100%; height: 100%; background: var(--accent);"></div></div>
          </div>
          <div style="background: var(--paper); border-radius: 10px; padding: 14px 16px; border: 1px solid var(--line);">
            <div style="display: flex; justify-content: space-between; font-size: 11px; color: var(--ink-2); margin-bottom: 8px;"><span>Transcription</span><span style="font-family: var(--mono); color: var(--accent);">✓ 1:42</span></div>
            <div style="height: 4px; background: var(--cream-3); border-radius: 2px; overflow: hidden;"><div style="width: 100%; height: 100%; background: var(--accent);"></div></div>
          </div>
          <div style="background: var(--paper); border-radius: 10px; padding: 14px 16px; border: 1px solid var(--accent);">
            <div style="display: flex; justify-content: space-between; font-size: 11px; color: var(--accent-ink); margin-bottom: 8px;"><span style="font-weight: 600;">Timestamps &amp; formatting</span><span style="font-family: var(--mono);">0:48</span></div>
            <div style="height: 4px; background: var(--accent-tint); border-radius: 2px; overflow: hidden;"><div style="width: 64%; height: 100%; background: var(--accent);"></div></div>
          </div>
          <div style="margin-top: auto; padding-top: 8px; border-top: 1px dashed var(--line-2); font-size: 11.5px; color: var(--ink-3);">Elapsed time: <span style="color: var(--ink); font-family: var(--mono);">2:44</span> · 1h 06min of audio processed</div>
        </div>
      </div>

      <!-- Feature 2 : Search -->
      <div class="feature-alt reverse">
        <div>
          <div class="eyebrow"><span style="color: var(--accent);">02</span> · Search</div>
          <h3 style="margin-top: 12px;">Find any passage in 5 seconds.</h3>
          <p>The transcript is fully searchable. Click any line to re-listen to that exact moment in the audio player.</p>
        </div>
        <div class="demo" style="padding: 22px;">
          <div style="font-family: var(--mono); font-size: 10px; color: var(--ink-3); letter-spacing: 0.08em; margin-bottom: 12px;">SEARCH IN TRANSCRIPT</div>
          <div style="background: var(--cream); border: 1px solid var(--line); border-radius: 10px; padding: 10px 14px; display: flex; gap: 8px; align-items: center; font-size: 13px;">
            <span style="color: var(--ink-3);">⌕</span>
            <span style="color: var(--ink);">CUDA</span>
            <span style="margin-left: auto; font-size: 10px; color: var(--ink-3); padding: 2px 6px; background: var(--paper); border: 1px solid var(--line); border-radius: 4px; font-family: var(--mono);">4 results</span>
          </div>
          <div style="margin-top: 14px; display: flex; flex-direction: column; gap: 6px; font-size: 12.5px;">
            <div style="background: var(--paper); border: 1px solid var(--line); border-radius: 8px; padding: 10px 12px; display: grid; grid-template-columns: 50px 1fr; gap: 10px; cursor: pointer;">
              <span style="font-family: var(--mono); color: var(--accent-ink); font-size: 10.5px;">12:42</span>
              <span style="color: var(--ink-2);">« We bet on <span style="background: var(--accent-soft); padding: 0 4px; border-radius: 3px;">CUDA</span> when nobody believed in it. »</span>
            </div>
            <div style="background: var(--paper); border: 1px solid var(--line); border-radius: 8px; padding: 10px 12px; display: grid; grid-template-columns: 50px 1fr; gap: 10px; cursor: pointer;">
              <span style="font-family: var(--mono); color: var(--accent-ink); font-size: 10.5px;">28:14</span>
              <span style="color: var(--ink-2);">« <span style="background: var(--accent-soft); padding: 0 4px; border-radius: 3px;">CUDA</span> became the moat. »</span>
            </div>
            <div style="background: var(--paper); border: 1px solid var(--line); border-radius: 8px; padding: 10px 12px; display: grid; grid-template-columns: 50px 1fr; gap: 10px; cursor: pointer;">
              <span style="font-family: var(--mono); color: var(--accent-ink); font-size: 10.5px;">1:14:08</span>
              <span style="color: var(--ink-2);">« Without <span style="background: var(--accent-soft); padding: 0 4px; border-radius: 3px;">CUDA</span>, AI would have taken ten years. »</span>
            </div>
            <div style="background: var(--paper); border: 1px solid var(--line); border-radius: 8px; padding: 10px 12px; display: grid; grid-template-columns: 50px 1fr; gap: 10px; cursor: pointer;">
              <span style="font-family: var(--mono); color: var(--accent-ink); font-size: 10.5px;">2:18:33</span>
              <span style="color: var(--ink-2);">« <span style="background: var(--accent-soft); padding: 0 4px; border-radius: 3px;">CUDA</span> 13 opens the path to quantum. »</span>
            </div>
          </div>
          <div style="margin-top: 14px; padding: 10px 12px; background: var(--cream); border-radius: 8px; font-size: 11.5px; color: var(--ink-3); display: flex; gap: 8px; align-items: center;">
            <span style="color: var(--accent);">▶</span> Click a result to jump to the exact moment in the player.
          </div>
        </div>
      </div>

      <!-- Feature 3 : Community — highlighted -->
      <div class="feature-alt reverse" style="background: var(--cream-2); border-radius: 24px; padding: 48px; margin-top: 32px; border: 1px solid var(--line);">
        <div>
          <div style="display: inline-flex; align-items: center; gap: 10px;">
            <span style="background: var(--accent); color: white; padding: 4px 10px; border-radius: 999px; font-family: var(--mono); font-size: 10px; letter-spacing: 0.08em;">NETWORK EFFECT</span>
            <span class="eyebrow"><span style="color: var(--accent);">03</span> · Community</span>
          </div>
          <h3 style="margin-top: 16px;">Benefit from the whole community's work.</h3>
          <p>If another Audioask user has already transcribed the episode you're looking for, you get it instantly — without spending your credits. The bigger the community, the more your library grows effortlessly.</p>
          <div style="margin-top: 24px; display: flex; align-items: baseline; gap: 12px;">
            <span style="font-family: var(--serif); font-size: 56px; line-height: 1; letter-spacing: -0.03em; color: var(--accent-ink);">+185M</span>
            <span style="font-size: 14px; color: var(--ink-3);">episodes already transcribed</span>
          </div>
        </div>
        <div class="demo" style="aspect-ratio: 4 / 3; padding: 22px;">
          <div style="font-family: var(--mono); font-size: 10px; color: var(--ink-3); letter-spacing: 0.08em; margin-bottom: 12px;">COMMUNITY LIBRARY</div>
          <div style="display: grid; grid-template-columns: repeat(4, 1fr); gap: 8px;">
            <div style="position: relative;"><img src="/assets/pod-acquired.jpg" alt="Acquired" style="aspect-ratio: 1; width: 100%; border-radius: 8px; object-fit: cover; display: block;" /><span style="position: absolute; top: 4px; right: 4px; background: var(--accent); color: white; font-size: 8px; padding: 1px 5px; border-radius: 6px;">✓</span></div>
            <div style="position: relative;"><img src="/assets/pod-tkp.jpg" alt="The Knowledge Project" style="aspect-ratio: 1; width: 100%; border-radius: 8px; object-fit: cover; display: block;" /><span style="position: absolute; top: 4px; right: 4px; background: var(--accent); color: white; font-size: 8px; padding: 1px 5px; border-radius: 6px;">✓</span></div>
            <div style="position: relative;"><img src="/assets/pod-lex.jpg" alt="Lex Fridman" style="aspect-ratio: 1; width: 100%; border-radius: 8px; object-fit: cover; display: block;" /><span style="position: absolute; top: 4px; right: 4px; background: var(--accent); color: white; font-size: 8px; padding: 1px 5px; border-radius: 6px;">✓</span></div>
            <div style="position: relative;"><img src="/assets/pod-huberman.jpg" alt="Huberman Lab" style="aspect-ratio: 1; width: 100%; border-radius: 8px; object-fit: cover; display: block;" /><span style="position: absolute; top: 4px; right: 4px; background: var(--accent); color: white; font-size: 8px; padding: 1px 5px; border-radius: 6px;">✓</span></div>
            <div style="position: relative;"><img src="/assets/pod-timferriss.jpg" alt="Tim Ferriss" style="aspect-ratio: 1; width: 100%; border-radius: 8px; object-fit: cover; display: block;" /><span style="position: absolute; top: 4px; right: 4px; background: var(--accent); color: white; font-size: 8px; padding: 1px 5px; border-radius: 6px;">✓</span></div>
            <div style="position: relative;"><img src="/assets/pod-founders.jpg" alt="Founders" style="aspect-ratio: 1; width: 100%; border-radius: 8px; object-fit: cover; display: block;" /><span style="position: absolute; top: 4px; right: 4px; background: var(--accent); color: white; font-size: 8px; padding: 1px 5px; border-radius: 6px;">✓</span></div>
            <div style="position: relative;"><img src="/assets/pod-a16z.jpg" alt="a16z" style="aspect-ratio: 1; width: 100%; border-radius: 8px; object-fit: cover; display: block;" /><span style="position: absolute; top: 4px; right: 4px; background: var(--accent); color: white; font-size: 8px; padding: 1px 5px; border-radius: 6px;">✓</span></div>
            <div style="position: relative;"><img src="/assets/pod-allin.jpg" alt="All-In" style="aspect-ratio: 1; width: 100%; border-radius: 8px; object-fit: cover; display: block;" /><span style="position: absolute; top: 4px; right: 4px; background: var(--accent); color: white; font-size: 8px; padding: 1px 5px; border-radius: 6px;">✓</span></div>
          </div>
          <div style="margin-top: 14px; background: var(--paper); border: 1px solid var(--accent); border-radius: 10px; padding: 12px 14px;">
