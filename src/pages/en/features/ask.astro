---
import Layout from '../../../layouts/Layout.astro';
import MobileTease from '../../../components/MobileTease.astro';
const APP_URL = 'https://dev.audioask.ai';
---

<Layout
  title="Ask AI questions about any podcast — Audioask"
  description="Ask questions in plain language about any episode or an entire channel. AI answers with verifiable, timestamped citations."
  activePage="features"
  lang="en"
  alternatePath="/fonctionnalites/interroger"
>

  <!-- HERO -->
  <section class="hero dotbg">
    <div class="container">
      <div class="interroger-hero-grid" style="display: grid; grid-template-columns: 1.05fr 1fr; gap: 64px; align-items: center;">
        <div>
          <div class="page-intro">Feature 02 · Ask AI</div>
          <h1 style="text-align: left;">
            Ask your questions.<br>
            <span class="em-serif">The episode</span> answers.
          </h1>
          <p class="lede" style="margin-top: 24px;">
            Every transcribed episode becomes content you can interrogate — in plain language, in your language.
          </p>
          <div class="hero-ctas" style="margin-top: 32px;">
            <a class="btn btn-primary lg" href={`${APP_URL}/signup`}>Try on an episode <span class="arrow">→</span></a>
            <a class="btn lg" href="/en/pricing">See plans</a>
          </div>
        </div>

        <!-- Live demo card -->
        <div class="ask-demo interroger-hero-visual">
          <div style="display: flex; justify-content: space-between; align-items: center;">
            <span class="eyebrow" style="font-size: 10px;">Acquired · #119 · 2h 47min</span>
            <span class="chip accent-soft" style="font-size: 11px;">✦ AUDIOASK</span>
          </div>
          <div class="ask-bubble q">What are the 3 book recommendations mentioned?</div>
          <div class="ask-bubble a">
            The guest cites three key books:<br>
            <div style="margin-top: 6px;"><span style="color: var(--accent); font-weight: 600;">1.</span> <b>Poor Charlie's Almanack</b> — on long-term thinking</div>
            <div><span style="color: var(--accent); font-weight: 600;">2.</span> <b>The Art of Worldly Wisdom</b> — a biography of ideas</div>
            <div><span style="color: var(--accent); font-weight: 600;">3.</span> <b>Influence</b> — an essay on persuasion</div>
            <div style="margin-top: 8px; padding-top: 8px; border-top: 1px dashed var(--line-2); font-size: 11.5px; color: var(--ink-3); display: flex; gap: 8px; align-items: center;">
              <span>↩ 3 citations</span>
              <span style="font-family: var(--mono); color: var(--accent-ink);">28:05</span>
              <span style="font-family: var(--mono); color: var(--accent-ink);">31:42</span>
              <span style="font-family: var(--mono); color: var(--accent-ink);">36:18</span>
            </div>
          </div>
          <div style="margin-top: 4px; background: var(--cream); border: 1px solid var(--line); border-radius: 12px; padding: 10px 14px; font-size: 13px; color: var(--ink-3); display: flex; align-items: center; gap: 8px;">
            <span>✎</span>
            <span style="font-style: italic;">Type your question…</span>
            <span style="margin-left: auto; width: 28px; height: 24px; border-radius: 6px; background: var(--accent); color: white; display: flex; align-items: center; justify-content: center;">→</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- EXAMPLE QUESTIONS -->
  <section class="section alt">
    <div class="container">
      <div class="center" style="max-width: 720px; margin: 0 auto;">
        <div class="eyebrow center" style="justify-content: center; display: inline-flex;"><span class="dot">●</span> Examples</div>
        <h2 style="margin-top: 16px;">What kind of questions<br><span class="serif-it">can you ask?</span></h2>
      </div>
      <div class="question-grid">
        <div class="question-card">Summarise the 3 key points of this episode.</div>
        <div class="question-card">What book recommendations are mentioned?</div>
        <div class="question-card">What did the guest say about AI regulation?</div>
        <div class="question-card">Which figures were cited on growth?</div>
        <div class="question-card">When is Charlie Munger mentioned?</div>
        <div class="question-card">Is there a debate on open-source vs closed-source?</div>
      </div>
      <p class="small center muted" style="margin-top: 18px;">…and any question you can phrase in plain language.</p>
    </div>
  </section>

  <!-- TWO MODES -->
  <section class="section">
    <div class="container">
      <div style="max-width: 720px;">
        <div class="eyebrow"><span class="dot">●</span> Two scopes</div>
        <h2 style="margin-top: 16px;">Query one episode —<br><span class="serif-it">or an entire channel</span> at once.</h2>
        <p class="lede" style="margin-top: 18px;">Depending on what you're looking for, Audioask widens or narrows the scope. One interface, two scopes.</p>
      </div>

      <div class="modes-grid">
        <div class="mode-card">
          <div class="eyebrow"><span style="color: var(--accent);">MODE 01</span></div>
          <h3 style="font-size: 28px; margin-top: 6px;">One episode.</h3>
          <p style="color: var(--ink-2); font-size: 15px; max-width: 44ch;">Ask questions about a single transcript. Ideal for summarising, quoting, or verifying a specific passage.</p>
          <div style="margin-top: 16px; padding: 18px; background: var(--cream-2); border-radius: 14px; border: 1px solid var(--line); display: flex; align-items: center; gap: 14px;">
            <div style="width: 48px; height: 48px; border-radius: 10px; background: linear-gradient(135deg, #5B7FD9, #2E4FB5); color: white; display: flex; align-items: center; justify-content: center; font-weight: 700; font-size: 11px;">#119</div>
            <div style="flex: 1;">
              <div style="font-size: 13px; font-weight: 600;">Nvidia · the decade</div>
              <div style="font-size: 11.5px; color: var(--ink-3);">Acquired · 2h 47min · 1 episode</div>
            </div>
            <span class="chip accent-soft">✦ Audioask</span>
          </div>
          <div class="mode-tags">
            <span class="mode-tag">● summary</span>
            <span class="mode-tag">● quote</span>
            <span class="mode-tag">● fact-check</span>
          </div>
        </div>

        <div class="mode-card accent">
          <div class="eyebrow"><span style="color: var(--accent);">MODE 02 · PRO</span></div>
          <h3 style="font-size: 28px; margin-top: 6px;">An entire channel. <span style="font-family: var(--mono); font-size: 11px; letter-spacing: 0.06em; padding: 2px 8px; border-radius: 999px; background: var(--ink); color: var(--cream); vertical-align: middle;">PRO</span></h3>
          <p style="color: var(--accent-deep); font-size: 15px; max-width: 44ch;">Query a whole podcast — all seasons combined — to detect trends, compare guests, and cross-reference themes.</p>
          <div style="margin-top: 16px; padding: 18px; background: var(--paper); border-radius: 14px; border: 1px solid var(--accent); display: flex; align-items: center; gap: 14px;">
            <div style="display: flex;">
              <div style="width: 36px; height: 36px; border-radius: 8px; background: linear-gradient(135deg, #5B7FD9, #2E4FB5); border: 2px solid var(--paper); display: flex; align-items: center; justify-content: center; color: white; font-weight: 700; font-size: 10px;">119</div>
              <div style="width: 36px; height: 36px; border-radius: 8px; background: linear-gradient(135deg, #5B7FD9, #2E4FB5); border: 2px solid var(--paper); margin-left: -10px; display: flex; align-items: center; justify-content: center; color: white; font-weight: 700; font-size: 10px;">118</div>
              <div style="width: 36px; height: 36px; border-radius: 8px; background: linear-gradient(135deg, #5B7FD9, #2E4FB5); border: 2px solid var(--paper); margin-left: -10px; display: flex; align-items: center; justify-content: center; color: white; font-weight: 700; font-size: 10px;">117</div>
              <div style="width: 36px; height: 36px; border-radius: 8px; background: var(--accent); border: 2px solid var(--paper); margin-left: -10px; display: flex; align-items: center; justify-content: center; color: white; font-weight: 700; font-size: 9px;">+139</div>
            </div>
            <div style="flex: 1;">
              <div style="font-size: 13px; font-weight: 600;">Acquired · full seasons</div>
              <div style="font-size: 11.5px; color: var(--accent-ink);">142 episodes · 312h audio</div>
            </div>
          </div>
          <div class="mode-tags">
            <span class="mode-tag">● trends</span>
            <span class="mode-tag">● cross-episodes</span>
            <span class="mode-tag">● over time</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- PROMPTS & LIBRARY -->
  <section class="section alt">
    <div class="container">
      <div class="feature-alt" style="border-top: 0; padding-top: 0;">
        <div>
          <div class="eyebrow"><span style="color: var(--accent);">01</span> · Saved prompts</div>
          <h3 style="margin-top: 12px;">Your prompts saved and ready to reuse.</h3>
          <p>Save the questions you ask regularly: "Summarise this episode", "What are the key quotes?", "What reading recommendations?" — click and it runs.</p>
        </div>
        <div class="demo" style="padding: 22px; display: flex; flex-direction: column; gap: 8px;">
          <div style="font-family: var(--mono); font-size: 10px; color: var(--ink-3); letter-spacing: 0.08em; margin-bottom: 6px;">MY SAVED PROMPTS · 8</div>
          <div style="background: var(--paper); border: 1px solid var(--accent); border-radius: 10px; padding: 10px 14px; display: flex; align-items: center; gap: 10px; font-size: 13px;">
            <span style="color: var(--accent);">★</span>
            <span style="flex: 1;">Client brief &mdash; angles &amp; actionable insights</span>
            <span class="chip accent-soft" style="height: 22px; font-size: 10.5px; padding: 0 8px;">▶</span>
          </div>
          <div style="background: var(--paper); border: 1px solid var(--line); border-radius: 10px; padding: 10px 14px; display: flex; align-items: center; gap: 10px; font-size: 13px;">
            <span style="color: var(--ink-3);">○</span>
            <span style="flex: 1;">Executive summary · 5 points</span>
            <span style="font-size: 11px; color: var(--ink-3); font-family: var(--mono);">used 42×</span>
          </div>
          <div style="background: var(--paper); border: 1px solid var(--line); border-radius: 10px; padding: 10px 14px; display: flex; align-items: center; gap: 10px; font-size: 13px;">
            <span style="color: var(--ink-3);">○</span>
            <span style="flex: 1;">Timestamped key quotes</span>
            <span style="font-size: 11px; color: var(--ink-3); font-family: var(--mono);">used 31×</span>
          </div>
          <div style="background: var(--paper); border: 1px solid var(--line); border-radius: 10px; padding: 10px 14px; display: flex; align-items: center; gap: 10px; font-size: 13px;">
            <span style="color: var(--ink-3);">○</span>
            <span style="flex: 1;">Books &amp; tools mentioned</span>
            <span style="font-size: 11px; color: var(--ink-3); font-family: var(--mono);">used 19×</span>
          </div>
          <div style="background: var(--paper); border: 1px solid var(--line); border-radius: 10px; padding: 10px 14px; display: flex; align-items: center; gap: 10px; font-size: 13px;">
            <span style="color: var(--ink-3);">○</span>
            <span style="flex: 1;">Fact-check &mdash; sources &amp; figures</span>
            <span style="font-size: 11px; color: var(--ink-3); font-family: var(--mono);">used 14×</span>
          </div>
        </div>
      </div>

      <div class="feature-alt reverse">
        <div>
          <div class="eyebrow"><span style="color: var(--accent);">02</span> · Saved results</div>
          <h3 style="margin-top: 12px;">Save your AI prompt results.</h3>
          <p>Every AI answer is saved in your library, tagged by episode and prompt. Find it again in two clicks.</p>
        </div>
        <div class="demo" style="padding: 22px;">
          <div style="font-family: var(--mono); font-size: 10px; color: var(--ink-3); letter-spacing: 0.08em; margin-bottom: 12px;">MY LIBRARY · ANSWERS</div>
          <div style="display: flex; flex-direction: column; gap: 8px;">
            <div style="background: var(--paper); border: 1px solid var(--line); border-radius: 10px; padding: 12px 14px; font-size: 13px;">
              <div style="display: flex; justify-content: space-between; align-items: center;">
                <b>Executive summary · #119 Acquired</b>
                <span style="font-family: var(--mono); font-size: 10px; color: var(--ink-3);">MAY 15</span>
              </div>
              <div style="color: var(--ink-3); font-size: 12px; margin-top: 4px;">3 key bets · CUDA, Mellanox, generative AI…</div>
            </div>
            <div style="background: var(--paper); border: 1px solid var(--line); border-radius: 10px; padding: 12px 14px; font-size: 13px;">
              <div style="display: flex; justify-content: space-between; align-items: center;">
                <b>Key quotes · #218 The Knowledge Project</b>
                <span style="font-family: var(--mono); font-size: 10px; color: var(--ink-3);">MAY 12</span>
              </div>
              <div style="color: var(--ink-3); font-size: 12px; margin-top: 4px;">5 timestamped citations · long-term decisions</div>
            </div>
            <div style="background: var(--paper); border: 1px solid var(--line); border-radius: 10px; padding: 12px 14px; font-size: 13px;">
              <div style="display: flex; justify-content: space-between; align-items: center;">
                <b>Client brief · 14 Lex Fridman episodes</b>
                <span style="font-family: var(--mono); font-size: 10px; color: var(--accent-ink);">CROSS-CHANNEL</span>
              </div>
              <div style="color: var(--ink-3); font-size: 12px; margin-top: 4px;">AI trends Q1 2026 · 2,200 words delivered</div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <MobileTease lang="en" />

  <!-- FAQ -->
  <section class="section">
    <div class="container">
      <div class="center" style="max-width: 720px; margin: 0 auto;">
        <div class="eyebrow center" style="justify-content: center; display: inline-flex;"><span class="dot">●</span> FAQ</div>
        <h2 style="margin-top: 16px;">Questions about <span class="serif-it">AI interrogation.</span></h2>
      </div>
      <div class="faq">
        <div class="faq-item">
          <span>Does the AI respond in English?</span><span class="plus">+</span>
          <div class="faq-answer">Yes. Whatever the original language of the podcast, you can ask your questions in English and receive the answer in English. Audioask understands both, responds in your language and cites the original text.</div>
        </div>
        <div class="faq-item">
          <span>Where do the answers come from? Are they verifiable?</span><span class="plus">+</span>
          <div class="faq-answer">Answers are generated from the episode transcript. Every answer is anchored in timestamped citations — you can always verify the source directly in the episode.</div>
        </div>
        <div class="faq-item">
          <span>Can I query multiple episodes at once?</span><span class="plus">+</span>
          <div class="faq-answer">Yes, with the Pro plan. The "entire channel" mode lets you query all episodes of a podcast in a single question. Ideal for trend analysis or comparing guests across multiple seasons.</div>
        </div>
        <div class="faq-item">
          <span>Which AI model do you use?</span><span class="plus">+</span>
          <div class="faq-answer">Audioask uses several state-of-the-art models depending on context size and request type (DeepSeek, Gemini). We regularly update our selection to offer the best performance.</div>
        </div>
        <div class="faq-item">
          <span>Are my prompts and results private?</span><span class="plus">+</span>
          <div class="faq-answer">Yes. Your questions and the generated answers are private and accessible only to you. They are neither shared nor used to train AI models.</div>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="section dark cta-final">
    <div class="container">
      <h2>Ask your first question<br><span class="em-serif">in the next 2 minutes.</span></h2>
      <p class="lede" style="margin: 0 auto 36px; max-width: 50ch; color: var(--night-text-2);">
        3 free AI analyses per month. No credit card required.
      </p>
      <a class="btn btn-primary lg" href={`${APP_URL}/signup`} style="height: 56px; font-size: 16px; padding: 0 28px;">Try it now <span class="arrow">→</span></a>
    </div>
  </section>

<style>
  @media (max-width: 768px) {
    .interroger-hero-grid { grid-template-columns: 1fr !important; gap: 40px !important; }
    .interroger-hero-visual { display: none; }
  }
</style>

</Layout>

<script>
document.querySelectorAll<HTMLElement>('.faq-item').forEach(item => {
  const toggle = () => {
    const wasOpen = item.classList.contains('open');
    document.querySelectorAll('.faq-item').forEach(i => i.classList.remove('open'));
    if (!wasOpen) item.classList.add('open');
  };
  item.addEventListener('click', toggle);
});
</script>
