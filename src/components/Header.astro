---
interface Props {
  activePage?: string;
}
const { activePage = '' } = Astro.props;
const APP_URL = 'https://app.audioask.ai';
---

<header class="site-header">
  <a href="/" class="site-logo">
    <span class="site-logo-mark">
      <svg width="14" height="14" viewBox="0 0 14 14" fill="none">
        <circle cx="7" cy="7" r="4" fill="white" opacity="0.9"/>
        <path d="M7 3L7 1M7 13L7 11M3 7L1 7M13 7L11 7" stroke="white" stroke-width="1.5" stroke-linecap="round" opacity="0.5"/>
      </svg>
    </span>
    AudioAsk
  </a>

  <nav class="site-nav">
    <div class="nav-dropdown">
      <a href="#" class={activePage === 'features' ? 'active' : ''}>Fonctionnalités</a>
      <div class="dropdown-menu">
        <a href="/fonctionnalites/transcrire" class="dropdown-item">
          <div class="dropdown-icon">
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5">
              <rect x="2" y="2" width="12" height="12" rx="2"/>
              <path d="M4.5 6h7M4.5 8.5h7M4.5 11h5"/>
            </svg>
          </div>
          <div class="dropdown-item-text">
            <span class="dropdown-item-title">Transcrire</span>
            <span class="dropdown-item-desc">Audio vers texte précis en minutes</span>
          </div>
        </a>
        <a href="/fonctionnalites/interroger" class="dropdown-item">
          <div class="dropdown-icon">
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5">
              <path d="M3 4h10v8H8l-3 3V12H3V4z"/>
              <circle cx="6.5" cy="8.5" r="0.75" fill="currentColor"/>
              <circle cx="8" cy="8.5" r="0.75" fill="currentColor"/>
              <circle cx="9.5" cy="8.5" r="0.75" fill="currentColor"/>
            </svg>
          </div>
          <div class="dropdown-item-text">
            <span class="dropdown-item-title">Interroger (IA)</span>
            <span class="dropdown-item-desc">Questions en langage naturel</span>
          </div>
        </a>
        <a href="/fonctionnalites/automatiser" class="dropdown-item">
          <div class="dropdown-icon">
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5">
              <circle cx="8" cy="8" r="5"/>
              <path d="M8 5v3l2 2"/>
            </svg>
          </div>
          <div class="dropdown-item-text">
            <span class="dropdown-item-title">Automatiser</span>
            <span class="dropdown-item-desc">Veille automatique par channel</span>
          </div>
        </a>
        <a href="/fonctionnalites/traduire" class="dropdown-item">
          <div class="dropdown-icon">
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5">
              <path d="M2 4h6M5 2v2M5 4c0 3 2 5 4 6M9 10c-2-1-3-3-4-6"/>
              <path d="M9 8h5M11.5 6l2 2-2 2"/>
            </svg>
          </div>
          <div class="dropdown-item-text">
            <span class="dropdown-item-title">Traduire</span>
            <span class="dropdown-item-desc">12 langues, texte + audio</span>
          </div>
        </a>
      </div>
    </div>
    <a href="/tarifs" class={activePage === 'tarifs' ? 'active' : ''}>Tarifs</a>
    <a href="/a-propos" class={activePage === 'about' ? 'active' : ''}>À propos</a>
    <a href="/pro" class={activePage === 'pro' ? 'active' : ''}>Pour les pros</a>
  </nav>

  <div class="site-header-right">
    <div class="lang-switch" id="lang-switch">
      <span>🇫🇷 FR</span>
      <div class="lang-menu">
        <a href="#" class="on">🇫🇷 Français</a>
        <a href="#">🇬🇧 English</a>
        <a href="#">🇩🇪 Deutsch</a>
        <a href="#">🇮🇹 Italiano</a>
        <a href="#">🇪🇸 Español</a>
      </div>
    </div>
    <a class="btn btn-ghost btn-sm" href={`${APP_URL}/login`}>Se connecter</a>
    <a class="btn btn-primary btn-sm" href={`${APP_URL}/signup`}>Essayer gratuitement</a>
  </div>
</header>

<script>
  // Language dropdown
  const langSwitch = document.getElementById('lang-switch');
  langSwitch?.addEventListener('click', (e) => {
    e.stopPropagation();
    langSwitch.classList.toggle('open');
  });
  document.addEventListener('click', () => {
    langSwitch?.classList.remove('open');
  });
</script>
